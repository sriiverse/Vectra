# ================================================================
# Vectra — Environment Configuration
# Copy this to .env and fill in your values
# ================================================================

# Database (use DATABASE_URL for production / Supabase)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=vectra
DB_PASSWORD=vectra_secret
DB_NAME=vectra_db

# CLIP Model
CLIP_MODEL=clip-ViT-B-32

# Cross-Encoder Reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Pexels API (free real product images)
PEXELS_API_KEY=

# Search defaults
DEFAULT_TOP_K_RETRIEVAL=50
DEFAULT_TOP_N_RERANK=10
TEXT_WEIGHT=0.3

# Offline mode for models (set to 1 if no internet, 0 to allow download)
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
